---
import "../styles/global.css";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Secure, air-gapped-ready tactical intelligence workstation for local LLM inference, doctrine-aware reasoning, and full data sovereignty." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Tactical Intelligence Workstation</title>
    <style>
      :root {
        --accent: #22d3ee;        /* cyan-400 */
        --accent-dim: #0e7490;    /* cyan-700 */
        --amber: #f59e0b;
        --red: #ef4444;
        --surface: #080f1b;
        --border: #1e2d3d;
        --border-strong: #2d4055;
      }

      body {
        background-color: #030b14;
        color: #cbd5e1;
        font-family: 'IBM Plex Mono', monospace;
      }

      /* Subtle dot-grid texture */
      .dot-grid {
        background-image: radial-gradient(circle, #1e2d3d 1px, transparent 1px);
        background-size: 28px 28px;
      }

      /* Scanline overlay */
      .scanlines::after {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          to bottom,
          transparent,
          transparent 2px,
          rgba(0,0,0,0.08) 2px,
          rgba(0,0,0,0.08) 4px
        );
        pointer-events: none;
        z-index: 1;
      }

      /* Glowing accent border on hover */
      .card-hover {
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      .card-hover:hover {
        border-color: var(--accent-dim);
        box-shadow: 0 0 0 1px #0e749030, inset 0 0 30px #0e749008;
      }

      /* Accent left-border on SOP steps */
      .sop-step {
        border-left: 2px solid var(--border-strong);
        transition: border-color 0.2s;
      }
      .sop-step:hover {
        border-left-color: var(--accent);
      }

      .tag {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 2px 8px;
        border-radius: 2px;
      }

      .glow-text {
        text-shadow: 0 0 20px rgba(34, 211, 238, 0.4);
      }
    </style>
  </head>

  <body class="antialiased selection:bg-cyan-500 selection:text-slate-950">

    <!-- Classification strip -->
    <div class="bg-amber-950/60 border-b border-amber-900/50 text-amber-400/80 text-[9px] font-bold tracking-widest uppercase text-center py-1 px-4">
      FOR OFFICIAL USE ONLY &nbsp;·&nbsp; FOUO &nbsp;·&nbsp; DISTRIBUTION AUTHORIZED TO OPERATIONAL PERSONNEL ONLY
    </div>

    <!-- Fixed header -->
    <header class="border-b border-[#1e2d3d] bg-[#030b14]/90 backdrop-blur-md fixed top-7 left-0 right-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">

        <!-- Left: system identity -->
        <div class="flex items-center gap-5">
          <div class="flex items-center gap-2.5">
            <div class="relative w-2 h-2">
              <span class="absolute inset-0 bg-cyan-400 rounded-full animate-ping opacity-60"></span>
              <span class="absolute inset-0 bg-cyan-400 rounded-full"></span>
            </div>
            <span class="text-[10px] font-bold tracking-[0.2em] text-white uppercase">
              Defence Node <span class="text-cyan-500 mx-1">//</span> Core
            </span>
          </div>

          <div class="hidden sm:flex items-center gap-3 border-l border-[#1e2d3d] pl-5 text-[9px] tracking-widest text-slate-500 uppercase font-medium">
            <span class="text-emerald-400 font-bold">● INFERENCE: LOCAL</span>
            <span class="text-slate-600">|</span>
            <span>TELEMETRY: NONE</span>
            <span class="text-slate-600">|</span>
            <span>SOVEREIGNTY: FULL</span>
          </div>
        </div>

        <!-- Right: nav + back -->
        <div class="flex items-center gap-6">
          <nav class="hidden md:flex items-center gap-6 text-[10px] uppercase tracking-widest text-slate-500 font-medium">
            <a href="#capabilities" class="hover:text-cyan-400 transition-colors duration-150">Capabilities</a>
            <a href="#demo" class="hover:text-cyan-400 transition-colors duration-150">Demo</a>
            <a href="#sop" class="hover:text-cyan-400 transition-colors duration-150">SOP</a>
            <a href="#opsec" class="hover:text-cyan-400 transition-colors duration-150">OPSEC</a>
            <a href="#deploy" class="hover:text-cyan-400 transition-colors duration-150">Deploy</a>
          </nav>
          <a href="/" class="text-[10px] border border-[#1e2d3d] bg-[#080f1b] px-3 py-1.5 text-slate-400 hover:border-cyan-700 hover:text-cyan-400 transition-all font-bold tracking-widest uppercase">
            ← Portfolio
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 space-y-12">

      <!-- ─── HERO ──────────────────────────────────────────────────── -->
      <section class="relative border border-[#1e2d3d] bg-[#080f1b] overflow-hidden dot-grid scanlines">
        <!-- Corner accents -->
        <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-cyan-500/60"></div>
        <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-cyan-500/60"></div>
        <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-cyan-500/20"></div>
        <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-cyan-500/20"></div>

        <!-- Top metadata bar -->
        <div class="relative z-10 border-b border-[#1e2d3d] px-6 sm:px-8 py-2 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <span class="tag bg-cyan-950/60 text-cyan-400 border border-cyan-900/60">System v2.4</span>
            <span class="tag bg-emerald-950/50 text-emerald-400 border border-emerald-900/50">Operational</span>
          </div>
          <span class="text-[9px] text-slate-600 tracking-widest hidden sm:block">SYS_ID: TIW-CORE-0041</span>
        </div>

        <div class="relative z-10 p-6 sm:p-10 space-y-6">
          <div class="space-y-1">
            <div class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase mb-3">
              01 // System Overview
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white uppercase leading-tight glow-text">
              Tactical Intelligence<br/>Workstation
            </h1>
            <p class="text-xs text-slate-500 tracking-widest uppercase mt-2">Air-Gapped Local LLM Infrastructure for Defence Operations</p>
          </div>

          <p class="text-sm text-slate-300 leading-relaxed max-w-2xl font-light">
            A secure, air-gapped-ready intelligence workstation enabling on-device processing of tactical intelligence, doctrine-aware reasoning, and visual analysis. All inference executes locally on operator hardware — no external API calls, no telemetry, no cloud dependency — with complete data sovereignty.
          </p>

          <div class="flex flex-wrap gap-3 pt-2">
            <a href="#deploy"
               class="px-5 py-2.5 text-[10px] uppercase font-bold tracking-widest bg-cyan-500 text-slate-950 hover:bg-cyan-400 transition-colors shadow-[0_0_24px_rgba(34,211,238,0.3)]">
              Request Deployment Build
            </a>
            <a href="#demo"
               class="px-5 py-2.5 text-[10px] uppercase font-bold tracking-widest border border-[#2d4055] bg-transparent text-slate-300 hover:border-cyan-700 hover:text-cyan-400 transition-all">
              System Demonstration
            </a>
          </div>
        </div>
      </section>

      <!-- ─── SYSTEM METRICS STRIP ──────────────────────────────────── -->
      <div class="grid grid-cols-2 sm:grid-cols-4 border border-[#1e2d3d] divide-x divide-[#1e2d3d] bg-[#080f1b]">
        {[
          { label: "Inference Mode", value: "100% Local", accent: true },
          { label: "Cloud Dependency", value: "Zero", accent: false },
          { label: "Data Egress", value: "None", accent: false },
          { label: "Network Required", value: "Offline Capable", accent: false },
        ].map(m => (
          <div class="px-5 py-4">
            <div class="text-[9px] tracking-widest text-slate-600 uppercase mb-1">{m.label}</div>
            <div class={`text-sm font-bold ${m.accent ? "text-cyan-400" : "text-slate-200"}`}>{m.value}</div>
          </div>
        ))}
      </div>

      <!-- ─── DEMONSTRATION ─────────────────────────────────────────── -->
      <section id="demo" class="space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase">02 // Operational Demo</span>
            <span class="flex items-center gap-1.5 tag bg-red-950/50 text-red-400 border border-red-900/50">
              <span class="w-1.5 h-1.5 bg-red-400 rounded-full animate-pulse inline-block"></span>
              Live Recording
            </span>
          </div>
          <span class="text-[9px] text-slate-600 tracking-widest hidden sm:block">REF: dLnUTrfEkYw</span>
        </div>

        <div class="border border-[#1e2d3d] bg-black overflow-hidden relative">
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/40 to-transparent z-10"></div>
          <div class="aspect-video w-full relative">
            <iframe
              class="absolute inset-0 w-full h-full border-0"
              src="https://www.youtube.com/embed/dLnUTrfEkYw"
              title="Tactical Intelligence Workstation Demonstration"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen>
            </iframe>
          </div>
        </div>
      </section>

      <!-- ─── CAPABILITY MATRIX ─────────────────────────────────────── -->
      <section id="capabilities" class="space-y-3">
        <div class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase">03 // Active Capability Matrix</div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[#1e2d3d]">
          {[
            {
              id: "CAP-01",
              title: "Tactical RAG",
              status: "Operational",
              body: "Ingest mission SITREPs, fragmentary orders, and geospatial overlays for instant retrieval and contextual cross-analysis against the live mission archive."
            },
            {
              id: "CAP-02",
              title: "Doctrine-Aware Reasoning",
              status: "Operational",
              body: "Automated cross-referencing of tactical data assets against MOD Joint Service Publications and active Rules of Engagement to flag compliance deviations."
            },
            {
              id: "CAP-03",
              title: "Visual Intelligence",
              status: "Operational",
              body: "Fully local analysis of inbound tactical imagery, structural landmarks, and potential threat corridors via on-device vision models with zero data exfiltration."
            },
            {
              id: "CAP-04",
              title: "Secure Reporting",
              status: "Operational",
              body: "One-command generation of formal SITREPs as sanitized PDF readouts, with automated 60-second secure file purge following document creation."
            },
          ].map(cap => (
            <div class="p-5 bg-[#080f1b] card-hover border border-transparent space-y-3 group">
              <div class="flex items-start justify-between gap-4">
                <div class="space-y-1">
                  <span class="text-[9px] text-slate-600 tracking-widest">{cap.id}</span>
                  <h3 class="text-xs font-bold text-white uppercase tracking-wider group-hover:text-cyan-400 transition-colors">
                    {cap.title}
                  </h3>
                </div>
                <span class="tag bg-emerald-950/40 text-emerald-500 border border-emerald-900/40 shrink-0">{cap.status}</span>
              </div>
              <p class="text-[11px] text-slate-400 leading-relaxed font-light">{cap.body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── STANDARD OPERATING PROCEDURES ────────────────────────── -->
      <section id="sop" class="space-y-3">
        <div class="flex items-center justify-between">
          <div class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase">04 // Standard Operating Procedures</div>
          <span class="tag bg-slate-800/50 text-slate-500 border border-slate-700/50">Unclassified // Releasable</span>
        </div>

        <div class="border border-[#1e2d3d] bg-[#080f1b] divide-y divide-[#1e2d3d]">

          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 sop-step pl-8 hover:bg-[#0a1220] transition-colors group">
            <div class="md:col-span-3 space-y-1">
              <div class="text-[9px] text-cyan-600 tracking-widest font-bold">STEP 01</div>
              <div class="text-xs font-bold text-white uppercase tracking-wide group-hover:text-cyan-400 transition-colors">Mission Ingestion</div>
            </div>
            <div class="md:col-span-9 text-[11px] text-slate-400 leading-relaxed font-light">
              Drag and drop or upload mission-specific PDFs. The system indexes each document into the Mission Archive and immediately generates a BLUF (Bottom Line Up Front) summary with source attribution.
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 sop-step pl-8 hover:bg-[#0a1220] transition-colors group">
            <div class="md:col-span-3 space-y-1">
              <div class="text-[9px] text-cyan-600 tracking-widest font-bold">STEP 02</div>
              <div class="text-xs font-bold text-white uppercase tracking-wide group-hover:text-cyan-400 transition-colors">Doctrine Ingestion</div>
            </div>
            <div class="md:col-span-9 space-y-3">
              <p class="text-[11px] text-slate-400 leading-relaxed font-light">
                To update the persistent doctrine knowledge base with JSPs or ROE cards, use the <code class="text-cyan-400 bg-slate-950 px-1.5 py-0.5 border border-slate-800 text-[10px]">/policy</code> route token prepended to your query:
              </p>
              <div class="bg-slate-950 border border-[#1e2d3d] border-l-2 border-l-cyan-700 px-4 py-3 text-[10px] text-slate-400 font-mono">
                <span class="text-slate-600">INPUT &gt;</span>&nbsp;<span class="text-slate-300">/policy [Attach PDF]</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 sop-step pl-8 hover:bg-[#0a1220] transition-colors group">
            <div class="md:col-span-3 space-y-1">
              <div class="text-[9px] text-cyan-600 tracking-widest font-bold">STEP 03</div>
              <div class="text-xs font-bold text-white uppercase tracking-wide group-hover:text-cyan-400 transition-colors">Querying & Analysis</div>
            </div>
            <div class="md:col-span-9 space-y-3">
              <p class="text-[11px] text-slate-400 leading-relaxed font-light">
                Query both archives concurrently using natural language. The system forms validated cross-references across mission data and doctrine automatically.
              </p>
              <div class="bg-slate-950 border border-[#1e2d3d] border-l-2 border-l-slate-700 px-4 py-3 text-[10px] space-y-2 font-mono">
                <div><span class="text-slate-600">QUERY &gt;</span>&nbsp;<span class="text-slate-300">"What is the PID requirement for technicals at objective ALFA?"</span></div>
                <div><span class="text-slate-600">QUERY &gt;</span>&nbsp;<span class="text-slate-300">"Summarize all sightings of the white pickup truck across the last 3 SITREPs."</span></div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-6 sop-step pl-8 hover:bg-[#0a1220] transition-colors group">
            <div class="md:col-span-3 space-y-1">
              <div class="text-[9px] text-amber-600 tracking-widest font-bold">STEP 04</div>
              <div class="text-xs font-bold text-white uppercase tracking-wide group-hover:text-amber-400 transition-colors">Formal Export</div>
            </div>
            <div class="md:col-span-9 space-y-3">
              <p class="text-[11px] text-slate-400 leading-relaxed font-light">
                Execute the <strong class="text-slate-200 font-semibold">Generate Formal SITREP</strong> route to produce a sanitized, standalone PDF readout from the current session context.
              </p>
              <div class="bg-amber-950/20 border border-amber-900/40 px-4 py-3 text-[10px] text-amber-300 font-mono leading-relaxed">
                <span class="text-amber-500 font-bold">[WARN] PURGE ACTIVE:</span>&nbsp;Generated reports are securely wiped from the local filesystem 60 seconds after creation. Download immediately upon generation.
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ─── OPSEC + HARDWARE ──────────────────────────────────────── -->
      <section id="opsec" class="space-y-3">
        <div class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase">05 // Security Architecture & Hardware Requirements</div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[#1e2d3d]">

          <!-- OPSEC -->
          <div class="p-6 bg-[#080f1b] space-y-5">
            <div class="flex items-center gap-2 pb-3 border-b border-[#1e2d3d]">
              <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-white">OPSEC Protocols</h3>
            </div>
            <div class="space-y-5">
              {[
                {
                  title: "Air-Gapped Binding",
                  body: "This node binds exclusively to loopback interface 127.0.0.1. External tracking telemetry routes are structurally omitted — not disabled, but absent."
                },
                {
                  title: "Non-Persistent Storage",
                  body: "All attached source documents are securely shredded via a 3-pass sector-level wipe following embedding completion. No residual data persists on disk."
                },
                {
                  title: "Local Inference Only",
                  body: "Heavy models (Gemma 27B, Moondream) execute natively within onboard GPU frameworks. No tokens leave the host machine at any point."
                },
              ].map(item => (
                <div class="space-y-1">
                  <div class="text-[10px] font-bold text-slate-200 tracking-wide">{item.title}</div>
                  <p class="text-[11px] text-slate-500 leading-relaxed font-light">{item.body}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Hardware -->
          <div class="p-6 bg-[#080f1b] space-y-5">
            <div class="flex items-center gap-2 pb-3 border-b border-[#1e2d3d]">
              <span class="w-1.5 h-1.5 bg-slate-500 rounded-full"></span>
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-white">Hardware Requirements</h3>
            </div>

            <table class="w-full text-[10px]">
              <thead>
                <tr class="border-b border-[#1e2d3d]">
                  <th class="text-left text-slate-600 tracking-widest uppercase pb-2 font-medium">Parameter</th>
                  <th class="text-left text-slate-600 tracking-widest uppercase pb-2 font-medium">Minimum</th>
                  <th class="text-left text-slate-600 tracking-widest uppercase pb-2 font-medium">Recommended</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[#12202e]">
                <tr>
                  <td class="py-2.5 text-slate-400 font-medium pr-4">VRAM / RAM</td>
                  <td class="py-2.5 text-slate-300">16 GB</td>
                  <td class="py-2.5 text-cyan-400">24 GB+</td>
                </tr>
                <tr>
                  <td class="py-2.5 text-slate-400 font-medium pr-4">Storage</td>
                  <td class="py-2.5 text-slate-300">20 GB free</td>
                  <td class="py-2.5 text-cyan-400">40 GB+ SSD</td>
                </tr>
                <tr>
                  <td class="py-2.5 text-slate-400 font-medium pr-4">GPU (NVIDIA)</td>
                  <td class="py-2.5 text-slate-300">RTX 3060 16GB</td>
                  <td class="py-2.5 text-cyan-400">RTX 4080+</td>
                </tr>
                <tr>
                  <td class="py-2.5 text-slate-400 font-medium pr-4">Apple Silicon</td>
                  <td class="py-2.5 text-slate-300">M1 24GB</td>
                  <td class="py-2.5 text-cyan-400">M3 Pro/Max 48GB</td>
                </tr>
                <tr>
                  <td class="py-2.5 text-slate-400 font-medium pr-4">Quantization</td>
                  <td class="py-2.5 text-slate-300">IQ4 / 4-bit</td>
                  <td class="py-2.5 text-cyan-400">Q6_K / 8-bit</td>
                </tr>
              </tbody>
            </table>
          </div>

        </div>
      </section>

      <!-- ─── DEPLOYMENT ─────────────────────────────────────────────── -->
      <section id="deploy" class="border border-[#1e2d3d] bg-[#080f1b] relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>

        <!-- Top bar -->
        <div class="border-b border-[#1e2d3d] px-6 py-3 flex items-center justify-between">
          <div class="text-[9px] font-bold tracking-[0.2em] text-cyan-500 uppercase">06 // Deployment Package Request</div>
          <span class="tag bg-amber-950/40 text-amber-500 border border-amber-900/40">Controlled Distribution</span>
        </div>

        <div class="p-6 sm:p-8 space-y-6">
          <p class="text-[11px] text-slate-400 leading-relaxed max-w-2xl font-light">
            Select your target architecture below. Each request routes a deployment bundle inquiry directly to the system administrator and includes pre-configured Ollama manifests, model download scripts, and setup documentation.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">

            <div class="border border-[#1e2d3d] bg-[#030b14] p-5 space-y-4 card-hover">
              <div class="space-y-1">
                <div class="text-[9px] text-slate-600 tracking-widest uppercase">Target Architecture</div>
                <div class="text-xs font-bold text-white tracking-wide">Windows &nbsp;/&nbsp; x86-64</div>
                <div class="text-[9px] text-slate-600">CUDA · DirectML · WSL2 supported</div>
              </div>
              <a
                href={`mailto:bradclemson97@gmail.com?subject=Tactical%20Intelligence%20Workstation%20%E2%80%94%20Windows%20Deployment%20Request&body=Hello%20Bradley%2C%0A%0AI%20am%20requesting%20the%20deployment%20bundle%20for%20the%20Windows%20(x86-64)%20version%20of%20the%20Tactical%20Intelligence%20Workstation.%0A%0AHost%20Specifications%20(optional)%3A%0A%20%20GPU%3A%20%0A%20%20VRAM%3A%20%0A%20%20RAM%3A%20%0A%0AThank%20you.`}
                class="block w-full text-center px-4 py-2 text-[10px] font-bold uppercase tracking-widest border border-[#2d4055] text-slate-300 hover:border-cyan-700 hover:text-cyan-400 hover:bg-cyan-950/10 transition-all"
              >
                Request — Windows Build
              </a>
            </div>

            <div class="border border-[#1e2d3d] bg-[#030b14] p-5 space-y-4 card-hover">
              <div class="space-y-1">
                <div class="text-[9px] text-slate-600 tracking-widest uppercase">Target Architecture</div>
                <div class="text-xs font-bold text-white tracking-wide">macOS &nbsp;/&nbsp; Apple Silicon</div>
                <div class="text-[9px] text-slate-600">M1 · M2 · M3 · M4 · Unified Memory</div>
