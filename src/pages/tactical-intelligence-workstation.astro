            <a
              href={`mailto:bradclemson97@gmail.com?subject=Tactical%20Intelligence%20Workstation%20-%20macOS%20Download%20Request&body=Hello%20Bradley,%0A%0AI%20am%20requesting%20the%20download%20package%20and%20deployment%20instructions%20for%20the%20macOS%20architecture%20version%20of%20the%20Tactical%20Intelligence%20Workstation.%0A%0AHost%20Compute%20Specifications:%20[Optional:%20Input%20RAM/Unified%20Memory%20details]%0A%0AThank%20you.`}
