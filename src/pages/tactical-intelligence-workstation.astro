        </div>
      </section>

    </main>

    <footer class="border-t border-slate-900 bg-slate-950 text-slate-600 text-[11px] py-8 text-center w-full">
      <div class="max-w-5xl mx-auto px-4 space-y-1.5 font-mono">
        <p class="text-slate-500 font-bold tracking-widest text-[10px]">TACTICAL INTELLIGENCE CORE WORKSTATION // OPERATIONAL INTERFACE</p>
