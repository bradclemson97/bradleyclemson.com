        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto pt-2">
          <div class="p-5 rounded-xl border border-slate-800 bg-slate-950/80 flex flex-col justify-between items-center text-center gap-4 hover:border-slate-700 transition-colors">
            <div class="space-y-1">
              <span class="text-[9px] uppercase font-bold tracking-widest text-slate-500 block font-mono">Architecture Target</span>
              <h4 class="text-xs font-bold text-slate-200 uppercase tracking-wide">Windows OS</h4>
            </div>
            <a
              href={`mailto:bradclemson97@gmail.com?subject=Tactical%20Intelligence%20Workstation%20-%20Windows%20Download%20Request&body=Hello%20Bradley,%0A%0AI%20am%20requesting%20the%20download%20package%20and%20deployment%20instructions%20for%20the%20Windows%20architecture%20version%20of%20the%20Tactical%20Intelligence%20Workstation.%0A%0AHost%20Compute%20Specifications:%20[Optional:%20Input%20RAM/GPU%20details]%0A%0AThank%20you.`}
              class="w-full inline-block px-4 py-2 bg-slate-900 hover:bg-slate-850 border border-slate-800 hover:border-slate-700 text-slate-200 text-xs font-bold uppercase rounded-md tracking-wider transition-all font-mono"
