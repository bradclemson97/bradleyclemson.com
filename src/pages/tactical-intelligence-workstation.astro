---
import { siteConfig } from "../config.ts";
import "../styles/global.css";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Secure, air-gapped-ready tactical intelligence workstation for local processing, doctrine-aware reasoning, and data sovereignty." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Tactical Intelligence Workstation | Defence Node</title>
  </head>
  <body class="bg-slate-950 text-slate-100 font-mono antialiased selection:bg-emerald-500 selection:text-slate-950">

    <header class="border-b border-slate-800 bg-slate-900/60 backdrop-blur fixed top-0 left-0 right-0 z-50 w-full">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <div class="w-2.5 h-2.5 bg-emerald-500 rounded-xs rotate-45 animate-pulse"></div>
            <span class="text-xs font-bold tracking-widest text-white uppercase">DEFENCE NODE // CORE</span>
          </div>
          <div class="hidden sm:inline-flex items-center gap-2 border-l border-slate-800 pl-4">
            <span class="text-[10px] font-medium tracking-wider text-emerald-400 uppercase bg-emerald-950/40 border border-emerald-900/60 px-2 py-0.5 rounded">SYS_STATUS: SECURE</span>
          </div>
        </div>

        <nav class="hidden md:flex items-center gap-6 text-[11px] uppercase tracking-widest text-slate-400 font-medium">
          <a href="#capabilities" class="hover:text-emerald-400 transition-colors">Capabilities</a>
          <a href="#demo" class="hover:text-emerald-400 transition-colors">Demo</a>
          <a href="#sop" class="hover:text-emerald-400 transition-colors">SOP</a>
          <a href="#opsec" class="hover:text-emerald-400 transition-colors">OPSEC</a>
        </nav>

        <div>
          <a href="/" class="text-xs border border-slate-800 bg-slate-950 px-3 py-1.5 rounded text-slate-400 hover:border-emerald-500 hover:text-emerald-400 transition-all font-bold tracking-wide">
            &larr; PORTFOLIO
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16 space-y-16">

      <section class="border border-slate-800 bg-linear-to-b from-slate-900/40 to-slate-950 rounded-xl p-6 sm:p-8 relative overflow-hidden w-full shadow-2xl">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:2.5rem_2.5rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-25 pointer-events-none"></div>

        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-6 border-b border-slate-800 relative z-10">
          <div class="space-y-3">
            <div class="inline-flex items-center gap-2 text-[10px] font-bold text-amber-400 bg-amber-950/30 border border-amber-900/60 px-2.5 py-1 rounded tracking-widest uppercase">
              CLASSIFICATION: FOUO // INTERNAL OPERATIONAL USE ONLY
            </div>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold tracking-tight text-white uppercase font-mono">
              🛡️ Tactical Intelligence Workstation
            </h1>
          </div>

          <div class="flex-shrink-0 bg-slate-950 border border-slate-800 p-2.5 rounded-xl shadow-inner flex items-center justify-center w-20 h-20 relative">
            <img
              src="/images/tactical-workstation-icon.png"
              alt="Tactical Intelligence Workstation Logo"
              class="w-full h-full object-contain z-10 rounded-lg"
              onerror="this.style.display='none'; document.getElementById('fallback-logo-svg').classList.remove('hidden');"
            />
            <div id="fallback-logo-svg" class="hidden absolute inset-0 flex items-center justify-center bg-slate-950 rounded-xl">
              <svg class="w-10 h-10 text-emerald-500/80" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.5-3h15M3.75 9h16.5M3 12h18M3.75 15h16.5M4.5 19.5h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
              </svg>
            </div>
          </div>
        </div>

        <div class="pt-6 space-y-6 relative z-10">
          <p class="text-slate-300 text-sm sm:text-base leading-relaxed text-justify w-full font-normal">
            Meet your secure, air-gapped-ready intelligence workstation. The terminal enables local processing of tactical intelligence, doctrine-aware reasoning, and visual analysis. All operations are performed 100% locally on your hardware using Large Language Models (LLMs) and Retrieval-Augmented Generation (RAG) with 100% data sovereignty.
          </p>
          <div class="flex flex-wrap gap-4 pt-2">
            <a href="#download" class="px-5 py-2.5 text-xs uppercase font-bold rounded bg-emerald-500 text-slate-950 hover:bg-emerald-400 transition-all tracking-wider shadow-[0_0_20px_rgba(16,185,129,0.25)]">
              Request Deployment Build &darr;
            </a>
            <a href="#demo" class="px-5 py-2.5 text-xs uppercase font-bold rounded border border-slate-800 bg-slate-950 text-slate-300 hover:text-white hover:border-slate-600 transition-all tracking-wider">
              System Demonstration Video
            </a>
          </div>
        </div>
      </section>

      <section id="demo" class="border border-slate-800 bg-slate-900/10 rounded-xl p-4 sm:p-6 space-y-4 w-full shadow-lg">
        <div class="flex items-center justify-between border-b border-slate-800 pb-3">
          <h2 class="text-xs font-bold uppercase tracking-widest text-white flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-500 animate-ping"></span>
            <span>📺 Live Operational Demonstration</span>
          </h2>
          <span class="text-[10px] text-slate-500 font-mono hidden sm:inline tracking-wider">REF_ID: dLnUTrfEkYw.SYS</span>
        </div>
        <div class="aspect-video w-full rounded-lg overflow-hidden bg-black border border-slate-900 shadow-2xl relative">
          <iframe
            class="w-full h-full border-0 absolute inset-0"
            src="https://www.youtube.com/embed/dLnUTrfEkYw"
            title="Tactical Intelligence Workstation Demonstration"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen>
          </iframe>
        </div>
      </section>

      <section id="capabilities" class="space-y-4 w-full">
        <div class="flex items-center gap-2 px-1">
          <span class="text-emerald-500 font-bold">//</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-emerald-400">Active Capability Matrix</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/20 space-y-2.5 hover:border-slate-700 transition-all group">
            <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2 group-hover:text-emerald-400 transition-colors">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Tactical RAG
            </h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Ingest mission SITREPs, orders, and maps for instant retrieval and contextual structural analysis.
            </p>
          </div>

          <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/20 space-y-2.5 hover:border-slate-700 transition-all group">
            <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2 group-hover:text-emerald-400 transition-colors">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Doctrine-Aware Reasoning
            </h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Automated cross-referencing of tactical data assets against MOD JSPs and active rules of engagement (ROE).
            </p>
          </div>

          <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/20 space-y-2.5 hover:border-slate-700 transition-all group">
            <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2 group-hover:text-emerald-400 transition-colors">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Visual Intel (Vision)
            </h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              Clinical, completely local analysis of inbound tactical imagery, structural landmarks, and potential threat corridors.
            </p>
          </div>

          <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/20 space-y-2.5 hover:border-slate-700 transition-all group">
            <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2 group-hover:text-emerald-400 transition-colors">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Secure Reporting
            </h3>
            <p class="text-xs text-slate-400 leading-relaxed">
              One-click generation of formal SITREPs matched with automated 60-second secure persistent file purging protocols.
            </p>
          </div>
        </div>
      </section>

      <section id="sop" class="border border-slate-800 bg-slate-900/10 rounded-xl p-6 space-y-6 w-full shadow-lg">
        <h2 class="text-xs font-bold uppercase tracking-widest text-white border-b border-slate-800 pb-3 flex items-center gap-2">
          <span>📋 Standard Operating Procedures (SOP)</span>
        </h2>

        <div class="space-y-6 text-xs sm:text-sm">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6">
            <div class="md:col-span-3 font-bold text-emerald-400 uppercase tracking-wider text-xs">1. Mission Ingestion</div>
            <div class="md:col-span-9 text-slate-400 leading-relaxed">
              Simply drag and drop or upload any mission-specific PDF. The system will index it safely into the Mission Archive and provide an immediate BLUF (Bottom Line Up Front) summary.
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6 border-t border-slate-900/80 pt-4">
            <div class="md:col-span-3 font-bold text-emerald-400 uppercase tracking-wider text-xs">2. Doctrine Ingestion</div>
            <div class="md:col-span-9 text-slate-400 space-y-2">
              <p>To update the permanent knowledge base with JSPs or ROE cards, prepend queries using the <code class="text-cyan-400 bg-slate-950 px-1.5 py-0.5 rounded border border-slate-800 text-[11px]">/policy</code> route selector token:</p>
              <div class="bg-slate-950 border border-slate-900 p-2.5 rounded-lg text-xs text-slate-500 font-mono">
                Example Query: <span class="text-slate-300">/policy [Attach PDF]</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6 border-t border-slate-900/80 pt-4">
            <div class="md:col-span-3 font-bold text-emerald-400 uppercase tracking-wider text-xs">3. Querying & Analysis</div>
            <div class="md:col-span-9 text-slate-400 space-y-2">
              <p>Ask system deployment questions naturally. The workstation queries both archives concurrently to form validated cross-references:</p>
              <div class="bg-slate-950 border border-slate-900 p-3 rounded-lg text-xs space-y-1.5 text-slate-400 font-mono border-l-2 border-emerald-500 pl-4 bg-slate-900/40">
                <p>&ldquo;What is the PID requirement for the technicals at objective ALFA?&rdquo;</p>
                <p>&ldquo;Summarize all sightings of the white pickup truck from the last 3 SITREPs.&rdquo;</p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6 border-t border-slate-900/80 pt-4">
            <div class="md:col-span-3 font-bold text-amber-500 uppercase tracking-wider text-xs">4. Formal Export</div>
            <div class="md:col-span-9 text-slate-400 space-y-2">
              <p>Execute the 📄 <strong class="text-slate-200">Generate Formal SITREP</strong> interactive route to assemble clean, fully sanitized standalone PDF readouts.</p>
              <div class="p-3 rounded-lg bg-amber-950/20 border border-amber-900/40 text-xs text-amber-300 font-mono leading-relaxed">
                <span class="text-amber-500 font-bold">[!] WARNING // SECURE PURGE ACTIVE:</span> Generated reports are completely shredded from the local filesystem drive exactly 60 seconds after creation. Download or preserve them immediately.
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="opsec" class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full">
        <div class="border border-slate-800 bg-slate-900/20 rounded-xl p-5 space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-200 border-b border-slate-800 pb-2 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span> 🔒 OPSEC & Security Protocols
          </h3>
          <ul class="space-y-3 text-xs text-slate-400">
            <li class="leading-relaxed">
              <strong class="text-slate-200 block mb-0.5">Air-Gapped Logic:</strong>
              This local node binds to loopback interface <code class="text-emerald-400 bg-slate-950 px-1 py-0.5 rounded border border-slate-800 font-mono text-[11px]">127.0.0.1</code>. External tracking telemetry routes are entirely omitted.
            </li>
            <li class="leading-relaxed">
              <strong class="text-slate-200 block mb-0.5">Non-Persistent Storage:</strong>
              All attached source target files are securely scrubbed via a deep 3-pass sector shredding sequence following embedding processing.
            </li>
            <li class="leading-relaxed">
              <strong class="text-slate-200 block mb-0.5">Local Inference Loops:</strong>
              Heavy models (<strong class="text-slate-300">Gemma 26B</strong> & <strong class="text-slate-300">Moondream</strong>) operate natively inside onboard GPU frameworks.
            </li>
          </ul>
        </div>

        <div class="border border-slate-800 bg-slate-900/20 rounded-xl p-5 space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-200 border-b border-slate-800 pb-2 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-slate-500 rounded-full"></span> ⚙️ Hardware Requirements
          </h3>
          <ul class="space-y-3 text-xs text-slate-400">
            <li class="leading-relaxed">
              <strong class="text-slate-300 block mb-0.5">VRAM / RAM Parameters:</strong>
              16GB+ minimum limit configuration (required for 4-bit / IQ4 quantized versioning arrays).
            </li>
            <li class="leading-relaxed">
              <strong class="text-slate-300 block mb-0.5">Required Local Storage Space:</strong>
              20GB+ free environment workspace capacity.
            </li>
            <li class="leading-relaxed">
              <strong class="text-slate-300 block mb-0.5">Target Processing Chips:</strong>
              NVIDIA RTX 3060/4060 Ti (16GB VRAM) or greater setups; or alternative Apple Silicon architecture Mac devices (M1/M2/M3/M4) holding 24GB+ Unified Memory blocks.
            </li>
          </ul>
        </div>
